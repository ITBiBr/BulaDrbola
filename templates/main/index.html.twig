{% extends 'base.html.twig' %}

{% block title %}Jan Bula a Václav Drbola{% endblock %}

{% block body %}


    <div class="bula-drbola overflow-hidden">
        <div class="container-fluid position-relative">
            <div class="navbar-minus"></div>
            <div class="text-center">
                <img class="img-fluid mt-lg-0 mt-1 bula-drbola-oriznuti-main-mobil" src = "{{ asset('images/bula_drbola.png') }}" alt="Jan Bula a Václav Drbola">

                <div class="d-flex justify-content-between position-absolute top-50 start-50 translate-middle-x mt-lg-0 mt-sm-1 mt-4 pb-3">
                    <h2 class="text-white text-uppercase text-start m-2 pt-3">Jan<br>Bula</h2>
                    <h1 class="text-secondary text-uppercase m-3 pt-3 fw-normal">&amp;</h1>
                    <h2 class="text-white text-uppercase text-start m-2 pt-3">Václav<br>Drbola</h2>

                </div>
                <div class="row position-absolute top-50 justify-content-center mt-5 pt-6 w-100">
                    <div class="col-12">
                        <h1 class="text-white text-uppercase m-2" style="position: relative; top:-7px">{{ globalVars.nastaveniWebu('hlavicka_1_mainpage') }}</h1>
                        <p class="fs-2 text-white m-0" style="position: relative; top:-10px">{{ globalVars.nastaveniWebu('hlavicka_2_mainpage') }}</p>
                        {% if globalVars.nastaveniWebu('tlacitko_link_hlavicka_mainpage') %}
                        <a href="{{ globalVars.nastaveniWebu('tlacitko_link_hlavicka_mainpage') }}" class="btn btn-primary rounded-pill border-3 button-mainpage"{% if globalVars.nastaveniWebu('tlacitko_target_hlavicka_mainpage') %} target="{{ globalVars.nastaveniWebu('tlacitko_target_hlavicka_mainpage') }}"{% endif %}><span class="fw-bold fs-3 mx-2">{{ globalVars.nastaveniWebu('tlacitko_text_hlavicka_mainpage') }}</span></a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid posun-240">


        <div class ="row justify-content-center video-bula-drbola">
            <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 col-10 pt-sm-0 pt-2">
                <div class="ratio ratio-16x9">
                    <iframe class = "rounded" src="https://www.youtube.com/embed/{{ globalVars.nastaveniWebu('video_id_main_page') }}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
                </div>
            </div>
        </div>
    </div>
    <div class="podbarveni">
        <div class="container-fluid posun-140">
            <div class="row justify-content-center">
                <div class="col-lg-11 col-12">
                    <div class="row mt-5"></div>
                    <div class="row justify-content-center">

                        <div class="col-xxl-3 col-xl-4 col-lg-5 col-10 pe-xl-2 pe-lg-0 pe-0">
                            <img class="img-fluid mx-auto d-block" src="{{ asset('images/odvaha.jpg') }}?v=2" alt="Odvaha">
                        </div>
                        <div class="col-xl-2 col-lg-3 col-10 ps-0">
                            <div>
                                {{ globalVars.textyStranek('ctnosti', 'main')|raw|nbsp_prepositions|strong_filter|div_filter }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid text-center">
            <div class="row justify-content-center">
                <div class="col-lg-11 col-12">
                    <div class="row justify-content-center">
                       <div class="col-xl-3 col-lg-4 col-sm-6 col-8">

                           <p>{{ globalVars.textyStranek('paticka-vystaviste', 'main')|raw|nbsp_prepositions }}</p>
                       </div>
                   </div>
                   <div class="row justify-content-center">
                       <div class="col-xl-6 col-lg-9 col-10">
                           {# {% if globalVars.muzuZverejnit %} #}
                               <a class="btn btn-outline-primary rounded-pill m-5 px-4 border-2" href="{{ path('app_slavnost_blahoreceni') }}">Více o slavnosti blahořečení</a>
                           {# {% else %}
                               <a class="btn btn-outline-primary rounded-pill m-5 px-4 border-2" href="{{ path('app_vystaviste') }}">Více o akci na výstavišti</a>
                           {% endif %} #}
                       </div>
                   </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
